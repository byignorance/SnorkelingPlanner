# 로컬 개발은 .env.local 사용 권장
# WORLD_TIDES_API_KEY가 없으면 조석 데이터는 fallback 경로로 계산
WORLD_TIDES_API_KEY=
WORLD_TIDES_API_URL=https://www.worldtides.info/api/v3
OPENMETEO_WEATHER_URL=https://api.open-meteo.com/v1/forecast
OPENMETEO_MARINE_URL=https://marine-api.open-meteo.com/v1/marine
NEXT_PUBLIC_APP_TITLE=스노클링 플래너
GOOGLE_MAPS_EMBED_API_KEY=
